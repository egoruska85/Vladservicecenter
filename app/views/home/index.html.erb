<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Сервисный центр</title>

  <!-- Bootstrap CSS -->


  <style>
    body {
      padding-top: 80px;

    }

    .hero {
      background: linear-gradient(135deg, #2563eb, #1e40af);
      color: white;
      padding: 100px 20px;
      text-align: center;
    }

    .hero h1 {
      font-weight: 700;
    }

    .section {
      padding: 80px 0;
    }

    .card:hover {
      transform: translateY(-5px);
      transition: 0.3s;


    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<%= render 'include/navbar' %>


<!-- HERO -->
<section class="hero">
  <h1 class="display-5 mb-3">Ремонт бытовой техники</h1>
  <p class="lead mb-4">Выезд мастера в день обращения. Гарантия до 12 месяцев.</p>
  <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center gap-3">
    <button type="button" class="btn btn-light btn-lg" data-bs-toggle="modal" data-bs-target="#exampleModal">
      Оставить заявку
    </button>
    <button type="button" class="btn btn-light btn-lg" data-bs-toggle="modal" data-bs-target="#exampleModal2">
      Консультация
    </button>
  </div>
</section>


<!-- Button trigger modal -->
<%= render "modals" %>



<!-- SERVICES -->
<section id="services" class="section">
  <div class="container text-center">
    <h2 class="mb-5">Наши услуги</h2>
    <div class="row g-4">
      <% @services.each do |service| %>
        <div class="col-md-6 col-lg-3">
          <div class="card p-4 shadow-sm h-100">
            <%= service.title.capitalize %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ADVANTAGES -->
<section id="advantages" class="section bg-light">
  <div class="container text-center">
    <h2 class="mb-5">Почему выбирают нас</h2>
    <div class="row g-4">

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Гарантия до 12 месяцев
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Бесплатная диагностика
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Оригинальные запчасти
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Работаем без выходных
        </div>
      </div>

    </div>
  </div>
</section>


<!-- CONTACTS -->
<section id="contacts" class="section">
  <div class="container text-center">
    <h2 class="mb-4">Контакты</h2>

    <p>📞 <%= phone_to @organization.phones.last.phone, class:"btn btn-light" %></p>
    <p>📍 Ессентуки</p>
    <p>🕒 Ежедневно с 9:00 до 21:00</p>
  </div>
</section>

<footer class="bg-dark text-white text-center py-4">
  © <%= Time.now.year %> Профессиональный сервис бытовой техники. Все права защищены.
</footer>

<!-- Bootstrap JS -->

</body>
</html>
