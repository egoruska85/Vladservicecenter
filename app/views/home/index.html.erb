<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Сервисный центр</title>

  <!-- Bootstrap CSS -->


  <style>
    body {
      padding-top: 80px;
    }

    .hero {
      background: linear-gradient(135deg, #2563eb, #1e40af);
      color: white;
      padding: 100px 20px;
      text-align: center;
    }

    .hero h1 {
      font-weight: 700;
    }

    .section {
      padding: 80px 0;
    }

    .card:hover {
      transform: translateY(-5px);
      transition: 0.3s;
    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm fixed-top">
  <div class="container">
    <%= link_to root_path, class:"navbar-brand fw-bold text-primary" do %>
      🔧 Сервис Центр
    <% end %>


    <!-- Кнопка бургера -->
    <button class="navbar-toggler"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#mainNavbar"
            aria-controls="mainNavbar"
            aria-expanded="false"
            aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Меню -->
    <div class="collapse navbar-collapse" id="mainNavbar">
      <ul class="navbar-nav ms-auto me-3 mb-2 mb-lg-0">
        <li class="nav-item">
          <a class="nav-link" href="#">Главная</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#services">Услуги</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#advantages">Преимущества</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="#contacts">Контакты</a>
        </li>
      </ul>

      <a href="#" class="btn btn-primary">
        Вызвать мастера
      </a>
    </div>

  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <h1 class="display-5 mb-3">Ремонт бытовой техники</h1>
  <p class="lead mb-4">Выезд мастера в день обращения. Гарантия до 12 месяцев.</p>
  <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center gap-3">
    <a href="#" class="btn btn-light btn-lg">
      Оставить заявку
    </a>
    <a href="#" class="btn btn-outline-light btn-lg">
      Консультация
    </a>
  </div>
</section>

<!-- SERVICES -->
<section id="services" class="section">
  <div class="container text-center">
    <h2 class="mb-5">Наши услуги</h2>
    <div class="row g-4">

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Ремонт стиральных машин
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Ремонт холодильников
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Ремонт посудомоечных машин
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Ремонт телевизоров
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ADVANTAGES -->
<section id="advantages" class="section bg-light">
  <div class="container text-center">
    <h2 class="mb-5">Почему выбирают нас</h2>
    <div class="row g-4">

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Гарантия до 12 месяцев
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Бесплатная диагностика
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Оригинальные запчасти
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="card p-4 shadow-sm h-100">
          Работаем без выходных
        </div>
      </div>

    </div>
  </div>
</section>

<!-- CONTACTS -->
<section id="contacts" class="section">
  <div class="container text-center">
    <h2 class="mb-4">Контакты</h2>
    <p>📞 +7 (___) ___-__-__</p>
    <p>📍 Ваш город</p>
    <p>🕒 Ежедневно с 9:00 до 21:00</p>
  </div>
</section>

<footer class="bg-dark text-white text-center py-4">
  © 2026 Сервисный центр. Все права защищены.
</footer>

<!-- Bootstrap JS -->


</body>
</html>
