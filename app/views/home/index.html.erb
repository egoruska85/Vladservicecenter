<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Сервисный центр</title>

  <!-- Bootstrap CSS -->


  <style>
    body {
      padding-top: 80px;

    }

    .hero {
      background-image:
      linear-gradient(
          to right,
          rgba(0, 0, 255, 0.3) 0%,
          rgba(0, 0, 255, 0.9) 50%,
          rgba(0, 0, 255, 0.3) 100%
          ),
        url('/images/cond1.png');
      color: white;
      padding: 100px 20px;
      text-align: center;
    }

    .hero h1 {
      font-weight: 700;
    }

    .section {
      padding: 80px 0;
    }

    .card:hover {
      transform: translateY(-5px);
      transition: 0.3s;


    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<%= render 'include/navbar' %>


<!-- HERO -->
<section class="hero" style="background-repeat: no-repeat; background-size: cover;  background-position: center;">
  <h1 class="display-5 mb-3">Ремонт бытовой техники</h1>
  <p class="lead mb-4">Выезд мастера в день обращения. Гарантия до 12 месяцев.</p>
  <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center gap-3">
    <button type="button" class="btn btn-dark btn-lg" data-bs-toggle="modal" data-bs-target="#exampleModal">
      Оставить заявку
    </button>
    <button type="button" class="btn btn-dark btn-lg" data-bs-toggle="modal" data-bs-target="#exampleModal2">
      Консультация
    </button>
  </div>
</section>


<!-- Button trigger modal -->
<%= render "modals" %>



<!-- SERVICES -->
<section id="services" class="section">

  <div class="container-fluid text-center parallax">
    <center>
      <div class="row g-4">
        <center>
          <div class="col-md-6 col-lg-3">
            <div class="card p-4 shadow-sm h-100" style="background-color: rgba(128, 128, 128, 0.7)">
              <h2 class="mb-5">Наши услуги</h2>
            </div>
          </div>
        </center>
      </div>
    </center>
    <div class="container">
      <div class="row g-4">
        <% @services.each do |service| %>
          <div class="col-md-6 col-lg-3">
            <div class="card p-4 shadow-lg h-100" style="background-color: rgba(128, 128, 128, 0.7)">
              <h4>
                <%= service.title.capitalize %>
              </h4>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>

<!-- ADVANTAGES -->

<section id="abouts" class="section bg-light">
  <div class="container text-center shadow-lg p-3 mb-5 bg-body-tertiary rounded">
    <br><br>
    <h2>О нас</h2>
    <%= simple_format @organization.about, style:"font-size: 15px;" %>
    <h4 class="mb-5">Почему выбирают нас</h4>
    <div class="row g-4">
      <% @entries.each do |enter| %>
        <div class="col-md-6 col-lg-3">
          <div class="card p-4 shadow-sm h-100">
            <%= enter.title %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>


<!-- CONTACTS -->
<section id="contacts" class="section">
  <div class="container text-center">
    <h2 class="mb-4">Контакты</h2>

    <p>📞 <%= phone_to @organization.phones.last.phone, class:"btn btn-light" %></p>
    <p>📍 Ессентуки</p>
    <p>🕒 Ежедневно с 9:00 до 21:00</p>
  </div>
</section>


<!-- Bootstrap JS -->

</body>
</html>
